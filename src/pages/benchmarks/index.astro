---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allBenchmarks = (await getCollection('benchmarks'))
  .filter((b) => !b.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || b.slug.localeCompare(a.slug));

// 分类统计
const categoryMap = new Map<string, number>();
allBenchmarks.forEach((b) => {
  categoryMap.set(b.data.category, (categoryMap.get(b.data.category) || 0) + 1);
});

const activeCount = allBenchmarks.filter(b => b.data.status === 'active').length;

// 优化热区统计
const highPriority = allBenchmarks.filter(b => (b.data.importance || 3) >= 4 && b.data.saturation !== '\u5df2\u9971\u548c');
const recentNew = allBenchmarks.filter(b => {
  const threeMonthsAgo = new Date();
  threeMonthsAgo.setMonth(threeMonthsAgo.getMonth() - 3);
  return b.data.date >= threeMonthsAgo;
});
const nearSaturated = allBenchmarks.filter(b => b.data.saturation === '\u63a5\u8fd1\u9971\u548c');
const saturated = allBenchmarks.filter(b => b.data.saturation === '\u5df2\u9971\u548c');

// 提取 SOTA 分数的数值部分（用于进度条）
function extractPercent(score: string): number | null {
  const m = score.match(/(\d+(?:\.\d+)?)\s*%/);
  if (m) return parseFloat(m[1]);
  const m2 = score.match(/^~?(\d+(?:\.\d+)?)/);
  if (m2) {
    const v = parseFloat(m2[1]);
    if (v <= 100) return v;
  }
  return null;
}

// 二级分类统计（按一级分类分组）
const subcategoryByCategory = new Map<string, Map<string, number>>();
allBenchmarks.forEach((b) => {
  const cat = b.data.category;
  const sub = b.data.subcategory || '';
  if (!sub) return;
  if (!subcategoryByCategory.has(cat)) subcategoryByCategory.set(cat, new Map());
  const subMap = subcategoryByCategory.get(cat)!;
  subMap.set(sub, (subMap.get(sub) || 0) + 1);
});

// 饱和度配色
const saturationConfig: Record<string, { label: string; color: string; bg: string }> = {
  '\u5df2\u9971\u548c': { label: '已饱和', color: 'text-slate-500 dark:text-slate-400', bg: 'bg-slate-100 dark:bg-slate-800' },
  '\u63a5\u8fd1\u9971\u548c': { label: '接近饱和', color: 'text-amber-600 dark:text-amber-400', bg: 'bg-amber-50 dark:bg-amber-950/30' },
  '\u672a\u9971\u548c': { label: '未饱和', color: 'text-emerald-600 dark:text-emerald-400', bg: 'bg-emerald-50 dark:bg-emerald-950/30' },
};

// 分类配色
const categoryColors: Record<string, { text: string; bg: string }> = {
  '推理': { text: 'text-blue-600 dark:text-blue-400', bg: 'bg-blue-50 dark:bg-blue-950/30' },
  '代码生成': { text: 'text-emerald-600 dark:text-emerald-400', bg: 'bg-emerald-50 dark:bg-emerald-950/30' },
  'Agent': { text: 'text-violet-600 dark:text-violet-400', bg: 'bg-violet-50 dark:bg-violet-950/30' },
  '数据': { text: 'text-cyan-600 dark:text-cyan-400', bg: 'bg-cyan-50 dark:bg-cyan-950/30' },
  '多模态': { text: 'text-pink-600 dark:text-pink-400', bg: 'bg-pink-50 dark:bg-pink-950/30' },
  '对齐与安全': { text: 'text-amber-600 dark:text-amber-400', bg: 'bg-amber-50 dark:bg-amber-950/30' },
  '长文本': { text: 'text-indigo-600 dark:text-indigo-400', bg: 'bg-indigo-50 dark:bg-indigo-950/30' },
  '领域专业': { text: 'text-rose-600 dark:text-rose-400', bg: 'bg-rose-50 dark:bg-rose-950/30' },
  '综合': { text: 'text-slate-600 dark:text-slate-400', bg: 'bg-slate-100 dark:bg-slate-800' },
  '其他': { text: 'text-slate-600 dark:text-slate-400', bg: 'bg-slate-100 dark:bg-slate-800' },
};
---

<BaseLayout title="评测" description="追踪 AI 领域重要的评测基准——分类、能力、构建方式、模型效果一览">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-teal-500 to-cyan-500 flex items-center justify-center text-white shadow-lg shadow-teal-500/25">
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-slate-900 dark:text-white">评测</h1>
          <p class="text-slate-600 dark:text-slate-400 mt-1">追踪 AI 领域重要的评测基准——分类、能力、构建方式、模型效果</p>
        </div>
      </div>

      <!-- Stats bar -->
      <div class="flex flex-wrap items-center gap-3 mt-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-semibold bg-teal-50 dark:bg-teal-950/30 text-teal-700 dark:text-teal-300">
          共 {allBenchmarks.length} 个基准
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-emerald-50 dark:bg-emerald-950/30 text-emerald-700 dark:text-emerald-300">
          {activeCount} 个活跃
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
          {categoryMap.size} 个分类
        </span>
      </div>
    </div>

    <!-- 优化热区：快捷筛选卡片 -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 mb-6" id="bench-hotzone">
      <button class="hotzone-btn group text-left p-3 rounded-xl border-2 border-red-200 dark:border-red-900/50 bg-red-50/50 dark:bg-red-950/20 hover:border-red-400 dark:hover:border-red-700 transition-all" data-hotzone="high-priority">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
          <span class="text-[11px] font-semibold text-red-700 dark:text-red-400">高优先级</span>
        </div>
        <div class="text-2xl font-bold text-red-600 dark:text-red-400">{highPriority.length}</div>
        <div class="text-[10px] text-red-500/70 dark:text-red-400/50 mt-0.5">重要 + 未饱和</div>
      </button>

      <button class="hotzone-btn group text-left p-3 rounded-xl border-2 border-blue-200 dark:border-blue-900/50 bg-blue-50/50 dark:bg-blue-950/20 hover:border-blue-400 dark:hover:border-blue-700 transition-all" data-hotzone="recent">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-[11px] font-semibold text-blue-700 dark:text-blue-400">近期新增</span>
        </div>
        <div class="text-2xl font-bold text-blue-600 dark:text-blue-400">{recentNew.length}</div>
        <div class="text-[10px] text-blue-500/70 dark:text-blue-400/50 mt-0.5">近 3 个月</div>
      </button>

      <button class="hotzone-btn group text-left p-3 rounded-xl border-2 border-amber-200 dark:border-amber-900/50 bg-amber-50/50 dark:bg-amber-950/20 hover:border-amber-400 dark:hover:border-amber-700 transition-all" data-hotzone="near-saturated">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-[11px] font-semibold text-amber-700 dark:text-amber-400">接近饱和</span>
        </div>
        <div class="text-2xl font-bold text-amber-600 dark:text-amber-400">{nearSaturated.length}</div>
        <div class="text-[10px] text-amber-500/70 dark:text-amber-400/50 mt-0.5">即将失去区分度</div>
      </button>

      <button class="hotzone-btn group text-left p-3 rounded-xl border-2 border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/30 hover:border-slate-400 dark:hover:border-slate-600 transition-all" data-hotzone="saturated">
        <div class="flex items-center gap-2 mb-1">
          <span class="text-[11px] font-semibold text-slate-600 dark:text-slate-400">已饱和</span>
        </div>
        <div class="text-2xl font-bold text-slate-500 dark:text-slate-400">{saturated.length}</div>
        <div class="text-[10px] text-slate-400/70 dark:text-slate-500/50 mt-0.5">仅做基线参考</div>
      </button>
    </div>

    <!-- Controls: Search + Sort + Category Filter -->
    <div class="space-y-3 mb-6">
      <!-- Search + Sort row -->
      <div class="flex flex-wrap items-center gap-3">
        <!-- Search -->
        <div class="relative flex-1 min-w-[200px]">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
          </svg>
          <input
            id="bench-search"
            type="text"
            placeholder="搜索基准名称、能力、标签..."
            class="w-full pl-9 pr-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white text-sm focus:outline-none focus:ring-2 focus:ring-teal-500"
          />
        </div>

        <!-- Sort -->
        <select
          id="bench-sort"
          class="px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 text-slate-900 dark:text-white text-xs font-medium focus:outline-none focus:ring-2 focus:ring-teal-500"
        >
          <option value="date-desc">发布时间 ↓</option>
          <option value="date-asc">发布时间 ↑</option>
          <option value="priority-desc">优化优先级 ↓</option>
          <option value="importance-desc">重要度 ↓</option>
          <option value="name-asc">名称 A→Z</option>
        </select>
      </div>

      <!-- Category filter pills -->
      <div class="flex flex-wrap gap-1.5" id="bench-categories">
        <button
          class="bench-cat-btn px-3 py-1.5 rounded-lg text-xs font-semibold transition-all bg-teal-100 dark:bg-teal-900/40 text-teal-700 dark:text-teal-300 ring-1 ring-teal-300 dark:ring-teal-700"
          data-category="all"
        >
          全部 ({allBenchmarks.length})
        </button>
        {[...categoryMap.entries()].sort((a, b) => b[1] - a[1]).map(([cat, count]) => {
          const colors = categoryColors[cat] || categoryColors['其他'];
          return (
            <button
              class={`bench-cat-btn px-3 py-1.5 rounded-lg text-xs font-medium transition-all ${colors.bg} ${colors.text} hover:ring-1 hover:ring-current`}
              data-category={cat}
            >
              {cat} ({count})
            </button>
          );
        })}
      </div>

      <!-- Subcategory filter pills (dynamic, shown when a category is selected) -->
      <div class="flex flex-wrap gap-1.5 hidden" id="bench-subcategories">
        {[...subcategoryByCategory.entries()].map(([cat, subMap]) => (
          [...subMap.entries()].sort((a, b) => b[1] - a[1]).map(([sub, count]) => (
            <button
              class={`bench-sub-btn px-2.5 py-1 rounded-md text-[11px] font-medium transition-all bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:ring-1 hover:ring-teal-400`}
              data-parent-category={cat}
              data-subcategory={sub}
              style="display:none"
            >
              {sub} ({count})
            </button>
          ))
        ))}
      </div>
    </div>

    <!-- Benchmark Cards -->
    <div id="bench-list" class="space-y-3">
      {allBenchmarks.map((bench) => {
        const colors = categoryColors[bench.data.category] || categoryColors['其他'];
        const formattedDate = bench.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
        const importance = bench.data.importance || 3;
        const saturation = bench.data.saturation;
        const subcategory = bench.data.subcategory || '';
        const satCfg = saturation ? saturationConfig[saturation] : null;
        // 优化优先级：importance × 饱和度权重
        const satWeight = saturation === '\u5df2\u9971\u548c' ? 0.2 : saturation === '\u63a5\u8fd1\u9971\u548c' ? 0.6 : 1.0;
        const priority = Math.round(importance * satWeight * 10);
        // SOTA 进度
        const topScore = bench.data.topResults.length > 0 ? bench.data.topResults[0].score : '';
        const sotaPct = extractPercent(topScore);
        return (
          <a
            href={`/benchmarks/${bench.slug}`}
            class="bench-card group block card p-4 sm:p-5 hover:border-teal-300 dark:hover:border-teal-700 hover:shadow-lg hover:shadow-teal-500/5 transition-all duration-200"
            data-category={bench.data.category}
            data-subcategory={subcategory}
            data-date={bench.data.date.toISOString()}
            data-name={bench.data.benchName}
            data-importance={importance}
            data-saturation={saturation || ''}
            data-priority={priority}
            data-results={bench.data.topResults.length}
            data-search={`${bench.data.benchName} ${bench.data.description || ''} ${bench.data.abilities.join(' ')} ${bench.data.tags.join(' ')} ${bench.data.category} ${subcategory} ${bench.data.org} ${bench.data.metric || ''} ${saturation || ''}`}
          >
            <div class="flex flex-col sm:flex-row sm:items-start gap-3">
              {/* Left */}
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-1.5">
                  <span class={`px-2 py-0.5 rounded-md text-[11px] font-semibold ${colors.bg} ${colors.text}`}>
                    {bench.data.category}
                  </span>
                  {/* 二级分类 */}
                  {subcategory && (
                    <span class="px-1.5 py-0.5 rounded text-[10px] font-medium bg-slate-50 dark:bg-slate-800/60 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700">
                      {subcategory}
                    </span>
                  )}
                  {/* 重要度星标 */}
                  <span class="inline-flex items-center gap-0.5 text-[11px]" title={`重要度 ${importance}/5`}>
                    {[...Array(5)].map((_, i) => (
                      <svg class={`w-3 h-3 ${i < importance ? 'text-amber-400' : 'text-slate-200 dark:text-slate-700'}`} fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </span>
                  {/* 饱和度徽章 */}
                  {satCfg && (
                    <span class={`px-1.5 py-0.5 rounded text-[10px] font-medium ${satCfg.bg} ${satCfg.color}`}>
                      {satCfg.label}
                    </span>
                  )}
                  {bench.data.venue && (
                    <span class="px-2 py-0.5 rounded-md text-[11px] font-medium bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
                      {bench.data.venue}
                    </span>
                  )}
                  <span class="text-[11px] text-slate-400 dark:text-slate-500">{bench.data.org}</span>
                  <span class="text-[11px] text-slate-400 dark:text-slate-500">{formattedDate}</span>
                </div>

                <h2 class="text-base font-semibold text-slate-900 dark:text-white group-hover:text-teal-600 dark:group-hover:text-teal-400 transition-colors leading-snug">
                  {bench.data.benchName}
                  {bench.data.version && (
                    <span class="ml-1.5 text-xs font-normal text-slate-400 dark:text-slate-500">{bench.data.version}</span>
                  )}
                </h2>

                {bench.data.description && (
                  <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 line-clamp-1">{bench.data.description}</p>
                )}

                <div class="flex flex-wrap items-center gap-1.5 mt-2">
                  {bench.data.metric && (
                    <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-mono bg-teal-50 dark:bg-teal-950/30 text-teal-600 dark:text-teal-400">
                      {bench.data.metric}
                    </span>
                  )}
                  {bench.data.dataSize && (
                    <span class="text-[10px] text-slate-400 dark:text-slate-500">{bench.data.dataSize}</span>
                  )}
                  {bench.data.abilities.slice(0, 3).map((ability) => (
                    <span class="px-1.5 py-0.5 rounded text-[10px] bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
                      {ability}
                    </span>
                  ))}
                </div>
              </div>

              {/* Right: SOTA progress + Top results */}
              {bench.data.topResults.length > 0 && (
                <div class="sm:w-52 shrink-0">
                  {/* SOTA 进度条 */}
                  {sotaPct !== null && (
                    <div class="mb-2">
                      <div class="flex items-center justify-between text-[10px] mb-0.5">
                        <span class="text-slate-400 dark:text-slate-500">SOTA</span>
                        <span class={`font-mono font-bold ${sotaPct >= 95 ? 'text-slate-400' : sotaPct >= 80 ? 'text-amber-500' : 'text-emerald-500'}`}>{topScore}</span>
                      </div>
                      <div class="h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                        <div
                          class={`h-full rounded-full transition-all ${sotaPct >= 95 ? 'bg-slate-300 dark:bg-slate-600' : sotaPct >= 80 ? 'bg-amber-400' : sotaPct >= 50 ? 'bg-emerald-400' : 'bg-red-400'}`}
                          style={`width: ${Math.min(sotaPct, 100)}%`}
                        ></div>
                      </div>
                      <div class="text-[9px] text-slate-400 dark:text-slate-600 mt-0.5 text-right">
                        {sotaPct >= 95 ? '\u2190 \u5df2\u9971\u548c' : sotaPct >= 80 ? '\u2190 \u63a5\u8fd1\u5929\u82b1\u677f' : `\u2190 \u8fd8\u6709 ${Math.round(100 - sotaPct)}% \u7a7a\u95f4`}
                      </div>
                    </div>
                  )}
                  <div class="space-y-0.5">
                    {bench.data.topResults.slice(0, 3).map((result, idx) => (
                      <div class="flex items-center justify-between gap-2 text-[11px]">
                        <span class={`truncate ${idx === 0 ? 'font-semibold text-slate-800 dark:text-slate-200' : 'text-slate-500 dark:text-slate-400'}`}>
                          {idx === 0 ? '🥇' : idx === 1 ? '🥈' : '🥉'} {result.model}
                        </span>
                        <span class="shrink-0 font-mono text-teal-600 dark:text-teal-400 font-medium">{result.score}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>

    <!-- Empty state -->
    <div id="bench-empty" class="hidden text-center py-16">
      <div class="text-4xl mb-3">🔍</div>
      <p class="text-slate-500 dark:text-slate-400 text-sm">没有匹配的评测基准</p>
    </div>

    <!-- Result count -->
    <div id="bench-count" class="text-center mt-6 text-xs text-slate-400 dark:text-slate-500"></div>
  </div>
</BaseLayout>

<script is:inline>
(function() {
  var searchInput = document.getElementById('bench-search');
  var sortSelect = document.getElementById('bench-sort');
  var catButtons = document.querySelectorAll('.bench-cat-btn');
  var subButtons = document.querySelectorAll('.bench-sub-btn');
  var subContainer = document.getElementById('bench-subcategories');
  var hotzoneButtons = document.querySelectorAll('.hotzone-btn');
  var cards = document.querySelectorAll('.bench-card');
  var listEl = document.getElementById('bench-list');
  var emptyEl = document.getElementById('bench-empty');
  var countEl = document.getElementById('bench-count');

  var activeCategory = 'all';
  var activeSubcategory = 'all';
  var activeHotzone = 'none';
  var searchDebounce;

  function showSubcategories(category) {
    if (category === 'all') {
      subContainer.classList.add('hidden');
      subButtons.forEach(function(b) { b.style.display = 'none'; });
      return;
    }
    var hasAny = false;
    subButtons.forEach(function(b) {
      if (b.getAttribute('data-parent-category') === category) {
        b.style.display = '';
        b.classList.remove('ring-1', 'ring-teal-400', 'bg-teal-50', 'dark:bg-teal-950/30', 'text-teal-600', 'dark:text-teal-400');
        hasAny = true;
      } else {
        b.style.display = 'none';
      }
    });
    subContainer.classList.toggle('hidden', !hasAny);
  }

  function matchHotzone(card) {
    if (activeHotzone === 'none') return true;
    var imp = parseInt(card.getAttribute('data-importance')) || 3;
    var sat = card.getAttribute('data-saturation') || '';
    var dateStr = card.getAttribute('data-date');
    switch (activeHotzone) {
      case 'high-priority':
        return imp >= 4 && sat !== '\u5df2\u9971\u548c';
      case 'recent':
        var d = new Date(dateStr);
        var cutoff = new Date();
        cutoff.setMonth(cutoff.getMonth() - 3);
        return d >= cutoff;
      case 'near-saturated':
        return sat === '\u63a5\u8fd1\u9971\u548c';
      case 'saturated':
        return sat === '\u5df2\u9971\u548c';
      default:
        return true;
    }
  }

  function applyFilters() {
    var query = (searchInput.value || '').trim().toLowerCase();
    var sortMode = sortSelect.value;
    var visibleCards = [];

    cards.forEach(function(card) {
      var cat = card.getAttribute('data-category');
      var sub = card.getAttribute('data-subcategory') || '';
      var searchText = (card.getAttribute('data-search') || '').toLowerCase();

      var matchCat = activeCategory === 'all' || cat === activeCategory;
      var matchSub = activeSubcategory === 'all' || sub === activeSubcategory;
      var matchSearch = !query || searchText.indexOf(query) !== -1;
      var matchHz = matchHotzone(card);

      if (matchCat && matchSub && matchSearch && matchHz) {
        card.style.display = '';
        visibleCards.push(card);
      } else {
        card.style.display = 'none';
      }
    });

    // Sort
    visibleCards.sort(function(a, b) {
      switch (sortMode) {
        case 'date-desc':
          return new Date(b.getAttribute('data-date')) - new Date(a.getAttribute('data-date'));
        case 'date-asc':
          return new Date(a.getAttribute('data-date')) - new Date(b.getAttribute('data-date'));
        case 'priority-desc':
          var pA = parseInt(a.getAttribute('data-priority')) || 0;
          var pB = parseInt(b.getAttribute('data-priority')) || 0;
          return pB - pA || new Date(b.getAttribute('data-date')) - new Date(a.getAttribute('data-date'));
        case 'importance-desc':
          var impA = parseInt(a.getAttribute('data-importance')) || 3;
          var impB = parseInt(b.getAttribute('data-importance')) || 3;
          return impB - impA || new Date(b.getAttribute('data-date')) - new Date(a.getAttribute('data-date'));
        case 'name-asc':
          return (a.getAttribute('data-name') || '').localeCompare(b.getAttribute('data-name') || '');
        default:
          return 0;
      }
    });

    visibleCards.forEach(function(card) { listEl.appendChild(card); });
    emptyEl.classList.toggle('hidden', visibleCards.length > 0);

    var total = cards.length;
    countEl.textContent = visibleCards.length < total
      ? '\u663e\u793a ' + visibleCards.length + ' / ' + total + ' \u4e2a\u57fa\u51c6'
      : '';
  }

  // Hotzone filter
  hotzoneButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var hz = btn.getAttribute('data-hotzone');
      if (activeHotzone === hz) {
        activeHotzone = 'none'; // toggle off
      } else {
        activeHotzone = hz;
        // auto-switch to priority sort when clicking high-priority
        if (hz === 'high-priority') sortSelect.value = 'priority-desc';
      }
      // Update hotzone button styles
      hotzoneButtons.forEach(function(b) {
        if (b.getAttribute('data-hotzone') === activeHotzone) {
          b.classList.add('ring-2', 'ring-offset-1', 'scale-[1.02]');
        } else {
          b.classList.remove('ring-2', 'ring-offset-1', 'scale-[1.02]');
        }
      });
      applyFilters();
    });
  });

  // Category filter
  catButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      activeCategory = btn.getAttribute('data-category');
      activeSubcategory = 'all';
      activeHotzone = 'none';
      hotzoneButtons.forEach(function(b) { b.classList.remove('ring-2', 'ring-offset-1', 'scale-[1.02]'); });
      catButtons.forEach(function(b) {
        if (b.getAttribute('data-category') === activeCategory) {
          b.classList.add('ring-1', 'ring-teal-300', 'dark:ring-teal-700', 'bg-teal-100', 'dark:bg-teal-900/40', 'text-teal-700', 'dark:text-teal-300', 'font-semibold');
        } else {
          b.classList.remove('ring-1', 'ring-teal-300', 'dark:ring-teal-700', 'bg-teal-100', 'dark:bg-teal-900/40', 'text-teal-700', 'dark:text-teal-300', 'font-semibold');
        }
      });
      showSubcategories(activeCategory);
      applyFilters();
    });
  });

  // Subcategory filter
  subButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var clicked = btn.getAttribute('data-subcategory');
      activeSubcategory = activeSubcategory === clicked ? 'all' : clicked;
      subButtons.forEach(function(b) {
        if (b.style.display === 'none') return;
        if (b.getAttribute('data-subcategory') === activeSubcategory) {
          b.classList.add('ring-1', 'ring-teal-400', 'bg-teal-50', 'dark:bg-teal-950/30', 'text-teal-600', 'dark:text-teal-400');
        } else {
          b.classList.remove('ring-1', 'ring-teal-400', 'bg-teal-50', 'dark:bg-teal-950/30', 'text-teal-600', 'dark:text-teal-400');
        }
      });
      applyFilters();
    });
  });

  searchInput.addEventListener('input', function() {
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(applyFilters, 150);
  });

  sortSelect.addEventListener('change', applyFilters);
  countEl.textContent = '';
})();
</script>
