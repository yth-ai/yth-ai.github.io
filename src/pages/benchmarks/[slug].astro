---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const benchmarks = (await getCollection('benchmarks'))
    .filter((b) => !b.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || b.slug.localeCompare(a.slug));

  return benchmarks.map((bench, index) => ({
    params: { slug: bench.slug },
    props: {
      bench,
      prevPost: index > 0 ? { slug: benchmarks[index - 1].slug, title: benchmarks[index - 1].data.benchName } : null,
      nextPost: index < benchmarks.length - 1 ? { slug: benchmarks[index + 1].slug, title: benchmarks[index + 1].data.benchName } : null,
    },
  }));
}

const { bench, prevPost, nextPost } = Astro.props;
const { Content } = await render(bench);

const categoryColors: Record<string, { text: string; bg: string }> = {
  '推理': { text: 'text-blue-600 dark:text-blue-400', bg: 'bg-blue-50 dark:bg-blue-950/30' },
  '代码生成': { text: 'text-emerald-600 dark:text-emerald-400', bg: 'bg-emerald-50 dark:bg-emerald-950/30' },
  'Agent': { text: 'text-violet-600 dark:text-violet-400', bg: 'bg-violet-50 dark:bg-violet-950/30' },
  '数据': { text: 'text-cyan-600 dark:text-cyan-400', bg: 'bg-cyan-50 dark:bg-cyan-950/30' },
  '多模态': { text: 'text-pink-600 dark:text-pink-400', bg: 'bg-pink-50 dark:bg-pink-950/30' },
  '对齐与安全': { text: 'text-amber-600 dark:text-amber-400', bg: 'bg-amber-50 dark:bg-amber-950/30' },
  '长文本': { text: 'text-indigo-600 dark:text-indigo-400', bg: 'bg-indigo-50 dark:bg-indigo-950/30' },
  '领域专业': { text: 'text-rose-600 dark:text-rose-400', bg: 'bg-rose-50 dark:bg-rose-950/30' },
  '综合': { text: 'text-slate-600 dark:text-slate-400', bg: 'bg-slate-100 dark:bg-slate-800' },
  '其他': { text: 'text-slate-600 dark:text-slate-400', bg: 'bg-slate-100 dark:bg-slate-800' },
};

const colors = categoryColors[bench.data.category] || categoryColors['其他'];
const formattedDate = bench.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${bench.data.benchName} | 评测`} description={bench.data.description}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Back link -->
    <a href="/benchmarks" class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      返回评测
    </a>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class={`px-2.5 py-1 rounded-lg text-xs font-semibold ${colors.bg} ${colors.text}`}>
          {bench.data.category}
        </span>
        {bench.data.subcategory && (
          <span class="px-2 py-0.5 rounded text-xs font-medium bg-slate-50 dark:bg-slate-800/60 text-slate-500 dark:text-slate-400 border border-slate-200 dark:border-slate-700">
            {bench.data.subcategory}
          </span>
        )}
        {bench.data.saturation && (
          <span class={`px-2 py-0.5 rounded text-xs font-medium ${bench.data.saturation === '\u5df2\u9971\u548c' ? 'bg-slate-100 dark:bg-slate-800 text-slate-500' : bench.data.saturation === '\u63a5\u8fd1\u9971\u548c' ? 'bg-amber-50 dark:bg-amber-950/30 text-amber-600 dark:text-amber-400' : 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-600 dark:text-emerald-400'}`}>
            {bench.data.saturation}
          </span>
        )}
        {bench.data.importance && (
          <span class="inline-flex items-center gap-0.5" title={`重要度 ${bench.data.importance}/5`}>
            {[...Array(5)].map((_, i) => (
              <svg class={`w-3 h-3 ${i < bench.data.importance ? 'text-amber-400' : 'text-slate-200 dark:text-slate-700'}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </span>
        )}
        {bench.data.venue && (
          <span class="px-2.5 py-1 rounded-lg text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
            {bench.data.venue}
          </span>
        )}
        {bench.data.status !== 'active' && (
          <span class={`px-2.5 py-1 rounded-lg text-xs font-medium ${bench.data.status === 'superseded' ? 'bg-amber-50 dark:bg-amber-950/30 text-amber-600 dark:text-amber-400' : 'bg-slate-100 dark:bg-slate-800 text-slate-400'}`}>
            {bench.data.status === 'superseded' ? '已替代' : '已废弃'}
          </span>
        )}
      </div>

      <h1 class="text-3xl font-bold text-slate-900 dark:text-white leading-tight">
        {bench.data.benchName}
        {bench.data.version && (
          <span class="ml-2 text-lg font-normal text-slate-400 dark:text-slate-500">{bench.data.version}</span>
        )}
      </h1>

      {bench.data.description && (
        <p class="text-lg text-slate-600 dark:text-slate-400 mt-2">{bench.data.description}</p>
      )}

      <div class="flex items-center gap-3 mt-3 text-sm text-slate-500 dark:text-slate-400">
        <span>{bench.data.org}</span>
        <span class="text-slate-300 dark:text-slate-600">·</span>
        <time datetime={bench.data.date.toISOString()}>{formattedDate}</time>
      </div>
    </header>

    <!-- 考察能力（醒目展示）-->
    {bench.data.abilities.length > 0 && (
      <div class="card p-5 mb-6 border-l-4 border-l-teal-500">
        <h3 class="text-xs font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-wider mb-3">考察能力</h3>
        <div class="flex flex-wrap gap-2">
          {bench.data.abilities.map((ability) => (
            <span class="px-3 py-1.5 rounded-lg text-sm font-medium bg-teal-50 dark:bg-teal-950/30 text-teal-700 dark:text-teal-300">
              {ability}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Info Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <!-- 构建信息 -->
      <div class="card p-5">
        <h3 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-3">构建信息</h3>
        <dl class="space-y-2 text-sm">
          {bench.data.dataSize && (
            <div class="flex justify-between">
              <dt class="text-slate-500 dark:text-slate-400">数据规模</dt>
              <dd class="text-slate-900 dark:text-white font-medium">{bench.data.dataSize}</dd>
            </div>
          )}
          {bench.data.construction && (
            <div class="flex justify-between">
              <dt class="text-slate-500 dark:text-slate-400">构建方式</dt>
              <dd class="text-slate-900 dark:text-white font-medium">{bench.data.construction}</dd>
            </div>
          )}
          {bench.data.evalMethod && (
            <div class="flex justify-between">
              <dt class="text-slate-500 dark:text-slate-400">评测方式</dt>
              <dd class="text-slate-900 dark:text-white font-medium">{bench.data.evalMethod}</dd>
            </div>
          )}
          {bench.data.metric && (
            <div class="flex justify-between">
              <dt class="text-slate-500 dark:text-slate-400">核心指标</dt>
              <dd class="font-mono text-teal-600 dark:text-teal-400 font-medium">{bench.data.metric}</dd>
            </div>
          )}
        </dl>
      </div>

      <!-- 链接 -->
      <div class="card p-5">
        <h3 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-3">资源链接</h3>
        <div class="space-y-2">
          {bench.data.paper && (
            <a href={bench.data.paper.startsWith('http') ? bench.data.paper : `https://arxiv.org/abs/${bench.data.paper.replace('arXiv:', '')}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
              </svg>
              论文: {bench.data.paper}
            </a>
          )}
          {bench.data.code && (
            <a href={bench.data.code.startsWith('http') ? bench.data.code : `https://${bench.data.code}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              </svg>
              代码: {bench.data.code}
            </a>
          )}
          {bench.data.website && (
            <a href={bench.data.website} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-slate-600 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
              <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
              官网
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Top Results -->
    {bench.data.topResults.length > 0 && (
      <div class="card p-5 mb-8">
        <h3 class="text-xs font-semibold text-slate-400 dark:text-slate-500 uppercase tracking-wider mb-3">模型效果排行</h3>
        <div class="space-y-2">
          {bench.data.topResults.map((result, idx) => (
            <div class="flex items-center justify-between gap-3 py-2 px-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-colors">
              <div class="flex items-center gap-3">
                <span class="w-6 text-center text-sm">
                  {idx === 0 ? '🥇' : idx === 1 ? '🥈' : idx === 2 ? '🥉' : `${idx + 1}.`}
                </span>
                <span class={`text-sm ${idx === 0 ? 'font-semibold text-slate-900 dark:text-white' : 'text-slate-700 dark:text-slate-300'}`}>
                  {result.model}
                </span>
              </div>
              <div class="flex items-center gap-3">
                <span class="font-mono text-sm text-teal-600 dark:text-teal-400 font-medium">{result.score}</span>
                {result.date && (
                  <span class="text-[11px] text-slate-400 dark:text-slate-500">{result.date}</span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Content -->
    <article class="prose prose-slate dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-teal-600 dark:prose-a:text-teal-400 prose-blockquote:border-l-teal-400">
      <Content />
    </article>

    <!-- Tags -->
    {bench.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-8 pt-6 border-t border-slate-200 dark:border-slate-700">
        {bench.data.tags.map((tag) => (
          <span class="px-2.5 py-1 rounded-lg text-xs bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
            {tag}
          </span>
        ))}
      </div>
    )}

    <!-- Prev/Next Navigation -->
    <nav class="flex justify-between items-center mt-10 pt-8 border-t border-slate-200 dark:border-slate-700">
      {prevPost ? (
        <a href={`/benchmarks/${prevPost.slug}`} class="group flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          <span class="max-w-[200px] truncate">{prevPost.title}</span>
        </a>
      ) : <div />}
      {nextPost ? (
        <a href={`/benchmarks/${nextPost.slug}`} class="group flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 hover:text-teal-600 dark:hover:text-teal-400 transition-colors">
          <span class="max-w-[200px] truncate">{nextPost.title}</span>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      ) : <div />}
    </nav>
  </div>
</BaseLayout>
