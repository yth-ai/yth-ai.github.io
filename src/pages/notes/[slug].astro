---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<BaseLayout title={note.data.title} description={note.data.description}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Back link -->
    <a href="/notes" class="inline-flex items-center gap-1.5 text-sm text-slate-500 dark:text-slate-400 hover:text-primary-600 dark:hover:text-primary-400 transition-colors mb-8">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      返回笔记
    </a>

    <!-- Header -->
    <header class="mb-10">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white leading-tight">
        {note.data.title}
      </h1>
      {note.data.principle && (
        <blockquote class="mt-4 pl-4 border-l-4 border-primary-400 dark:border-primary-600 text-slate-600 dark:text-slate-300 italic text-base leading-relaxed">
          {note.data.principle}
        </blockquote>
      )}
      <div class="flex items-center gap-4 mt-4">
        <time class="text-sm text-slate-400 dark:text-slate-500">
          {note.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {note.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {note.data.tags.map((tag) => (
              <span class="px-2 py-0.5 rounded-md bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 text-xs">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Content -->
    <article class="prose prose-slate dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-primary-600 dark:prose-a:text-primary-400 prose-blockquote:border-l-primary-400">
      <Content />
    </article>
  </div>
</BaseLayout>
