---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allVoices = (await getCollection('voices'))
  .filter((v) => !v.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || b.data.volume - a.data.volume);

const platformConfig: Record<string, { label: string; color: string; bgColor: string }> = {
  youtube: { label: 'YouTube', color: 'text-red-600 dark:text-red-400', bgColor: 'bg-red-50 dark:bg-red-950/30' },
  podcast: { label: '播客', color: 'text-purple-600 dark:text-purple-400', bgColor: 'bg-purple-50 dark:bg-purple-950/30' },
  x: { label: 'X', color: 'text-slate-800 dark:text-slate-200', bgColor: 'bg-slate-100 dark:bg-slate-800' },
  bilibili: { label: 'Bilibili', color: 'text-cyan-600 dark:text-cyan-400', bgColor: 'bg-cyan-50 dark:bg-cyan-950/30' },
  blog: { label: '博客', color: 'text-emerald-600 dark:text-emerald-400', bgColor: 'bg-emerald-50 dark:bg-emerald-950/30' },
  news: { label: '新闻', color: 'text-amber-600 dark:text-amber-400', bgColor: 'bg-amber-50 dark:bg-amber-950/30' },
  other: { label: '其他', color: 'text-slate-600 dark:text-slate-400', bgColor: 'bg-slate-50 dark:bg-slate-800' },
};

const sourceTypeIcons: Record<string, string> = {
  video: 'M8 5v14l11-7z',
  podcast: 'M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z',
  thread: 'M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z',
  article: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z',
  live: 'M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z',
};

// Collect all platform stats
const platformStats = new Map<string, number>();
allVoices.forEach((v) => {
  v.data.items?.forEach((item) => {
    platformStats.set(item.platform, (platformStats.get(item.platform) || 0) + 1);
  });
});
const totalItems = [...platformStats.values()].reduce((a, b) => a + b, 0);
---

<BaseLayout title="前沿声浪" description="每日精选 YouTube、播客、X 等平台的 AI 前沿视频与讨论">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-10">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-rose-500 to-pink-500 flex items-center justify-center text-white shadow-lg shadow-rose-500/25">
          <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-slate-900 dark:text-white">前沿声浪</h1>
          <p class="text-slate-600 dark:text-slate-400 mt-1">每日精选 YouTube、播客、X 等平台的 AI 前沿视频与讨论</p>
        </div>
      </div>

      <!-- Platform Stats -->
      {totalItems > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {[...platformStats.entries()].sort((a, b) => b[1] - a[1]).map(([platform, count]) => {
            const cfg = platformConfig[platform] || platformConfig.other;
            return (
              <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium ${cfg.bgColor} ${cfg.color}`}>
                {cfg.label}
                <span class="opacity-60">{count}</span>
              </span>
            );
          })}
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400">
            共 {totalItems} 条 · {allVoices.length} 期
          </span>
        </div>
      )}
    </div>

    <!-- Episodes List -->
    {allVoices.length > 0 ? (
      <div class="space-y-6">
        {allVoices.map((voice) => {
          const formattedDate = voice.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
          const items = voice.data.items || [];
          return (
            <div class="card overflow-hidden hover:shadow-lg transition-shadow duration-300">
              {/* Episode header — links to detail page */}
              <a href={`/voices/${voice.slug}`} class="group block p-5 sm:p-6 pb-3 sm:pb-4">
                <div class="flex items-center gap-3 mb-2 text-xs">
                  <span class="px-2 py-0.5 rounded-full font-semibold bg-rose-50 dark:bg-rose-950/30 text-rose-700 dark:text-rose-300">
                    Vol.{voice.data.volume}
                  </span>
                  <time datetime={voice.data.date.toISOString()} class="text-slate-500 dark:text-slate-400">{formattedDate}</time>
                  {items.length > 0 && (
                    <span class="text-slate-400 dark:text-slate-500">{items.length} 条内容</span>
                  )}
                </div>
                <h2 class="text-lg font-semibold text-slate-900 dark:text-white group-hover:text-rose-600 dark:group-hover:text-rose-400 transition-colors mb-2">
                  {voice.data.title}
                </h2>
                {voice.data.description && (
                  <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">{voice.data.description}</p>
                )}
              </a>

              {/* Media items — each links directly to source */}
              {items.length > 0 && (
                <div class="border-t border-slate-100 dark:border-slate-800">
                  {items.map((item, idx) => {
                    const cfg = platformConfig[item.platform] || platformConfig.other;
                    return (
                      <a
                        href={item.sourceUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class:list={[
                          'group/item flex items-center gap-3 px-5 sm:px-6 py-3 hover:bg-rose-50/50 dark:hover:bg-rose-950/10 transition-colors',
                          idx < items.length - 1 ? 'border-b border-slate-50 dark:border-slate-800/50' : '',
                        ]}
                      >
                        {/* Play icon / source type */}
                        <div class={`shrink-0 w-8 h-8 rounded-lg flex items-center justify-center ${cfg.bgColor}`}>
                          {item.sourceType === 'video' ? (
                            <svg class={`w-4 h-4 ${cfg.color}`} fill="currentColor" viewBox="0 0 24 24">
                              <path d="M8 5v14l11-7z" />
                            </svg>
                          ) : (
                            <svg class={`w-4 h-4 ${cfg.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d={sourceTypeIcons[item.sourceType] || sourceTypeIcons.article} />
                            </svg>
                          )}
                        </div>
                        {/* Item info */}
                        <div class="flex-1 min-w-0">
                          <div class="flex items-center gap-2">
                            <span class={`text-[10px] font-semibold ${cfg.color}`}>{cfg.label}</span>
                            {item.duration && (
                              <span class="text-[10px] text-slate-400 dark:text-slate-500 font-mono">{item.duration}</span>
                            )}
                            {item.author && (
                              <span class="text-[10px] text-slate-400 dark:text-slate-500 truncate">· {item.author}</span>
                            )}
                          </div>
                          <p class="text-sm text-slate-700 dark:text-slate-300 group-hover/item:text-rose-600 dark:group-hover/item:text-rose-400 transition-colors truncate">
                            {item.title}
                          </p>
                        </div>
                        {/* External link icon */}
                        <svg class="shrink-0 w-4 h-4 text-slate-300 dark:text-slate-600 group-hover/item:text-rose-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                        </svg>
                      </a>
                    );
                  })}
                </div>
              )}

              {/* Tags */}
              {voice.data.tags.length > 0 && (
                <div class="px-5 sm:px-6 py-3 border-t border-slate-100 dark:border-slate-800">
                  <div class="flex flex-wrap gap-1.5">
                    {voice.data.tags.map((tag) => (
                      <span class="px-2 py-0.5 text-xs rounded-md bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400 font-medium">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-rose-50 dark:bg-rose-950/30 flex items-center justify-center text-rose-400">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
          </svg>
        </div>
        <p class="text-slate-500 dark:text-slate-400">暂无内容</p>
      </div>
    )}
  </div>
</BaseLayout>
