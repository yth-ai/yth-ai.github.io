---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonFormatter from '../../components/tools/JsonFormatter';
---

<BaseLayout title="JSON 格式化" description="美化、压缩和校验 JSON 数据">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">JSON 格式化</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">JSON 格式化</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">美化、压缩和校验 JSON 数据，支持语法错误提示</p>
    </div>

    <!-- Tool Component -->
    <JsonFormatter client:load />
  </div>
</BaseLayout>
