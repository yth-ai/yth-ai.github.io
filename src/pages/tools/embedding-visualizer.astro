---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmbeddingVisualizer from '../../components/tools/EmbeddingVisualizer';
---

<BaseLayout title="Embedding 全景工作台" description="3D 向量星图 · 经典向量算术 · 相似度热力图 · 训练直觉实验室——四个视角理解 Embedding">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">Embedding 全景工作台</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Embedding 全景工作台</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">3D 向量星图 · 经典 king−man+woman 算术 · 相似度热力图 · 训练直觉实验室</p>
    </div>

    <EmbeddingVisualizer client:load />
  </div>
</BaseLayout>
