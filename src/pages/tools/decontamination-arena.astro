---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DecontaminationArena from '../../components/tools/DecontaminationArena';
---

<BaseLayout title="Benchmark 污染检测游乐场" description="你的模型在作弊吗？污染注入模拟 · 检测器挑战赛 · 信任度计算器">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">Benchmark 污染检测游乐场</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Benchmark 污染检测游乐场</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">你的模型在"作弊"吗？模拟污染注入、挑战检测器、评估排行榜可信度</p>
    </div>
    <DecontaminationArena client:load />
  </div>
</BaseLayout>
