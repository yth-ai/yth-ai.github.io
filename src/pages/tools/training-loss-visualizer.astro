---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrainingLossVisualizer from '../../components/tools/TrainingLossVisualizer';
---

<BaseLayout title="训练 Loss 可视化" description="可视化 LLM 预训练 Loss 曲线，支持多曲线对比、学习率监控和异常检测">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">训练 Loss 可视化</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">训练 Loss 可视化</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">可视化预训练 Loss 曲线，支持多曲线对比、学习率监控和异常检测</p>
    </div>

    <!-- Tool Component -->
    <TrainingLossVisualizer client:load />
  </div>
</BaseLayout>
