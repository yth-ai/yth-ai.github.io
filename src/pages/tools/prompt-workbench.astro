---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PromptWorkbench from '../../components/tools/prompt-workbench/PromptWorkbench';
---

<BaseLayout title="Prompt 工程全景工作台" description="16 种模板 + A/B 对决 + 链式构建器 + 技术图鉴 — 从模板填空到 Prompt 系统化工程">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">Prompt 工程全景工作台</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Prompt 工程全景工作台</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">16 种模板 · A/B 对决 · 链式构建器 · 技术图鉴 — 从模板填空到 Prompt 系统化工程</p>
    </div>

    <!-- Tool Component -->
    <PromptWorkbench client:load />
  </div>
</BaseLayout>
