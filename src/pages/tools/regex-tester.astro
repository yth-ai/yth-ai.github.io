---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RegexTester from '../../components/tools/RegexTester';
---

<BaseLayout title="正则表达式测试" description="实时匹配和高亮正则表达式">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">正则表达式测试</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">正则表达式测试</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">实时匹配和高亮正则表达式，快速验证你的正则</p>
    </div>

    <!-- Tool Component -->
    <RegexTester client:load />
  </div>
</BaseLayout>
