---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReadingListManager from '../../components/tools/ReadingListManager';
import fs from 'node:fs';
import path from 'node:path';

// 构建时读取 reading-list.json，将仓库状态注入页面
let serverData: any[] = [];
try {
  const jsonPath = path.join(process.cwd(), 'src/data/reading-list.json');
  const content = fs.readFileSync(jsonPath, 'utf8');
  serverData = JSON.parse(content);
} catch {
  // 文件不存在或解析失败，用空数组
}
---

<BaseLayout title="精读队列" description="管理收藏的论文精读队列——自动检测、收藏、批量精读">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">精读队列</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">精读队列</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">收藏感兴趣的论文，自动触发深度精读并发布到研究栏目</p>
    </div>

    <!-- Manager Component -->
    <ReadingListManager client:load serverData={serverData} />
  </div>
</BaseLayout>
