---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LLMVocabulary from '../../components/tools/LLMVocabulary';
---

<BaseLayout title="英文词汇学习" description="专业英文词汇学习工具：闪卡记忆、分类浏览、间隔重复复习、标注管理、数据导入导出">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">英文词汇学习</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">英文词汇学习</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">覆盖 LLM、学术、商务等领域的英文词汇和表达，支持闪卡复习、间隔重复、标注管理和数据导入导出</p>
    </div>

    <!-- Tool Component -->
    <LLMVocabulary client:load />
  </div>
</BaseLayout>
