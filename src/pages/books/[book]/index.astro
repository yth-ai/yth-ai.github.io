---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allChapters = (await getCollection('book'))
    .filter((ch) => !ch.data.draft);

  // Get unique bookSlugs
  const bookSlugs = [...new Set(allChapters.map(ch => ch.data.bookSlug))];

  return bookSlugs.map((bookSlug) => ({
    params: { book: bookSlug },
    props: {
      bookSlug,
      chapters: allChapters
        .filter(ch => ch.data.bookSlug === bookSlug)
        .sort((a, b) => a.data.chapter - b.data.chapter),
    },
  }));
}

const { bookSlug, chapters } = Astro.props;

// Book metadata — all Tailwind classes are written as complete strings (no dynamic interpolation)
// so that Tailwind's static extraction can reliably pick them up at build time.
const booksMeta = {
  'llm-complete': {
    title: '大模型全书',
    description: '从架构设计到数据工程，从预训练到对齐，从推理优化到 Agent 系统——一本书带你成为大模型领域专家。基于一线实战经验，持续追踪前沿进展。',
    icon: '全',
    gradient: 'from-amber-500 to-orange-500',
    shadowColor: 'shadow-amber-500/25',
    badgeText: '持续更新中',
    badgeStyle: 'bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-300',
    // Pre-defined complete class strings for accent color usage
    hoverText: 'hover:text-amber-600 dark:hover:text-amber-400',
    heroGradient: 'bg-gradient-to-br from-amber-50 via-amber-50/50 to-slate-50 dark:from-amber-950/30 dark:via-amber-950/20 dark:to-slate-900 border border-amber-200/50 dark:border-amber-800/30',
    heroDecorGradient: 'from-amber-500/10 to-transparent',
    groupHoverText: 'group-hover:text-amber-600 dark:group-hover:text-amber-400',
    groupHoverArrow: 'group-hover:text-amber-500',
    targetAudience: [
      { title: '面向有基础的读者', desc: '假设你已具备机器学习基础知识，包括神经网络、反向传播和 Transformer 基本概念', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', colorClasses: 'bg-blue-50 dark:bg-blue-950/30 text-blue-600 dark:text-blue-400' },
      { title: '一线实战视角', desc: '不只讲论文，更分享工业界真实的技术选型、踩坑经验和最佳实践', icon: 'M13 10V3L4 14h7v7l9-11h-7z', colorClasses: 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-600 dark:text-emerald-400' },
      { title: '持续更新', desc: 'LLM 领域发展极快，本书定期吸收最新研究成果和工业实践，不会过时', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', colorClasses: 'bg-purple-50 dark:bg-purple-950/30 text-purple-600 dark:text-purple-400' },
    ],
    partColors: {
      '第一部分：基础篇': { gradient: 'from-blue-500 to-cyan-500', badge: 'bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800' },
      '第二部分：预训练': { gradient: 'from-emerald-500 to-teal-500', badge: 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800' },
      '第三部分：后训练与对齐': { gradient: 'from-purple-500 to-violet-500', badge: 'bg-purple-50 dark:bg-purple-950/30 text-purple-700 dark:text-purple-300 border-purple-200 dark:border-purple-800' },
      '第四部分：推理与部署': { gradient: 'from-orange-500 to-red-500', badge: 'bg-orange-50 dark:bg-orange-950/30 text-orange-700 dark:text-orange-300 border-orange-200 dark:border-orange-800' },
      '第五部分：前沿与展望': { gradient: 'from-rose-500 to-pink-500', badge: 'bg-rose-50 dark:bg-rose-950/30 text-rose-700 dark:text-rose-300 border-rose-200 dark:border-rose-800' },
    },
  },
  'key-moments': {
    title: '大模型的关键时刻',
    description: '九年、八个转折点，与一场未完的革命。不是教科书，而是一部认知简史——过滤信息噪音，只留真正改变行业走向的关键节点。',
    icon: '键',
    gradient: 'from-indigo-500 to-purple-500',
    shadowColor: 'shadow-indigo-500/25',
    badgeText: '已完稿',
    badgeStyle: 'bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300',
    hoverText: 'hover:text-indigo-600 dark:hover:text-indigo-400',
    heroGradient: 'bg-gradient-to-br from-indigo-50 via-indigo-50/50 to-slate-50 dark:from-indigo-950/30 dark:via-indigo-950/20 dark:to-slate-900 border border-indigo-200/50 dark:border-indigo-800/30',
    heroDecorGradient: 'from-indigo-500/10 to-transparent',
    groupHoverText: 'group-hover:text-indigo-600 dark:group-hover:text-indigo-400',
    groupHoverArrow: 'group-hover:text-indigo-500',
    targetAudience: [
      { title: '认知简史', desc: '不堆砌信息，而是梳理真正改变行业走向的关键转折——帮你在信息洪流中建立坐标系', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', colorClasses: 'bg-indigo-50 dark:bg-indigo-950/30 text-indigo-600 dark:text-indigo-400' },
      { title: '技术与叙事融合', desc: '每个关键时刻不仅讲发生了什么，更讲清楚"为什么这件事重要"和技术细节', icon: 'M13 10V3L4 14h7v7l9-11h-7z', colorClasses: 'bg-purple-50 dark:bg-purple-950/30 text-purple-600 dark:text-purple-400' },
      { title: '独立思考', desc: '有态度的筛选和判断，而不是中性百科——哪些是真正的拐点，哪些是噪音', icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', colorClasses: 'bg-rose-50 dark:bg-rose-950/30 text-rose-600 dark:text-rose-400' },
    ],
    partColors: {},
  },
  'data-engineering': {
    title: '大模型数据工程',
    description: '从预训练到对齐的全链路实践。第一本系统讲解大语言模型数据工程的专业书籍——一个过滤阈值的选择、一条坏样本的遗漏，可能让千万美元的训练功亏一篑。',
    icon: '数',
    gradient: 'from-emerald-500 to-teal-500',
    shadowColor: 'shadow-emerald-500/25',
    badgeText: '持续更新中',
    badgeStyle: 'bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-300',
    hoverText: 'hover:text-emerald-600 dark:hover:text-emerald-400',
    heroGradient: 'bg-gradient-to-br from-emerald-50 via-emerald-50/50 to-slate-50 dark:from-emerald-950/30 dark:via-emerald-950/20 dark:to-slate-900 border border-emerald-200/50 dark:border-emerald-800/30',
    heroDecorGradient: 'from-emerald-500/10 to-transparent',
    groupHoverText: 'group-hover:text-emerald-600 dark:group-hover:text-emerald-400',
    groupHoverArrow: 'group-hover:text-emerald-500',
    targetAudience: [
      { title: '认知优先', desc: '每个主题先讲认知是怎么演变的——业界曾经怎么想，后来发现了什么，为什么现在这么做', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7', colorClasses: 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-600 dark:text-emerald-400' },
      { title: '细节导向', desc: '不回避工程细节——阈值怎么选、边界情况怎么处理、踩过的坑和反直觉的发现', icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z', colorClasses: 'bg-teal-50 dark:bg-teal-950/30 text-teal-600 dark:text-teal-400' },
      { title: '案例驱动', desc: '大量引用真实案例：FineWeb、DCLM、DeepSeek、Llama、Qwen 等的公开数据策略', icon: 'M13 10V3L4 14h7v7l9-11h-7z', colorClasses: 'bg-cyan-50 dark:bg-cyan-950/30 text-cyan-600 dark:text-cyan-400' },
    ],
    partColors: {
      '第零部分：引言': { gradient: 'from-slate-500 to-slate-600', badge: 'bg-slate-50 dark:bg-slate-950/30 text-slate-700 dark:text-slate-300 border-slate-200 dark:border-slate-800' },
      '第一部分：预训练数据': { gradient: 'from-emerald-500 to-teal-500', badge: 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800' },
      '第二部分：中训练数据': { gradient: 'from-blue-500 to-cyan-500', badge: 'bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800' },
      '第三部分：SFT 数据': { gradient: 'from-purple-500 to-violet-500', badge: 'bg-purple-50 dark:bg-purple-950/30 text-purple-700 dark:text-purple-300 border-purple-200 dark:border-purple-800' },
      '第四部分：RL 数据': { gradient: 'from-orange-500 to-red-500', badge: 'bg-orange-50 dark:bg-orange-950/30 text-orange-700 dark:text-orange-300 border-orange-200 dark:border-orange-800' },
      '第五部分：横切主题': { gradient: 'from-rose-500 to-pink-500', badge: 'bg-rose-50 dark:bg-rose-950/30 text-rose-700 dark:text-rose-300 border-rose-200 dark:border-rose-800' },
      '第六部分：实战与展望': { gradient: 'from-amber-500 to-yellow-500', badge: 'bg-amber-50 dark:bg-amber-950/30 text-amber-700 dark:text-amber-300 border-amber-200 dark:border-amber-800' },
      '附录': { gradient: 'from-gray-500 to-gray-600', badge: 'bg-gray-50 dark:bg-gray-950/30 text-gray-700 dark:text-gray-300 border-gray-200 dark:border-gray-800' },
    },
  },
};

type BookMetaKey = keyof typeof booksMeta;
const meta = booksMeta[bookSlug as BookMetaKey] || booksMeta['llm-complete'];
const defaultPartColors = { gradient: 'from-slate-500 to-slate-600', badge: 'bg-slate-50 dark:bg-slate-950/30 text-slate-700 dark:text-slate-300 border-slate-200 dark:border-slate-800' };

// Filter chapters: for key-moments, chapter <= 0 means index/preface, treat them separately
const mainChapters = chapters.filter(ch => ch.data.chapter > 0);
const prefaceChapters = chapters.filter(ch => ch.data.chapter <= 0).sort((a, b) => a.data.chapter - b.data.chapter);

// Group main chapters by part
const partMap = new Map<string, typeof chapters>();
mainChapters.forEach((ch) => {
  const p = ch.data.part || '正文';
  if (!partMap.has(p)) partMap.set(p, []);
  partMap.get(p)!.push(ch);
});

const totalChapters = mainChapters.filter(ch => ch.data.chapter < 100).length;
const latestUpdate = chapters.length > 0
  ? new Date(Math.max(...chapters.map((ch) => (ch.data.updatedDate || ch.data.date).valueOf())))
  : new Date();
---

<BaseLayout title={meta.title} description={meta.description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-8">
      <a href="/books" class={`${meta.hoverText} transition-colors`}>书架</a>
      <span>/</span>
      <span class="text-slate-900 dark:text-white">{meta.title}</span>
    </nav>

    <!-- Hero -->
    <div class={`relative overflow-hidden rounded-2xl ${meta.heroGradient} p-8 sm:p-12 mb-12`}>
      <div class={`absolute top-0 right-0 w-64 h-64 bg-gradient-to-bl ${meta.heroDecorGradient} rounded-full blur-3xl`}></div>
      <div class="relative">
        <div class="flex items-center gap-3 mb-4">
          <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${meta.gradient} flex items-center justify-center text-white text-2xl font-bold shadow-lg ${meta.shadowColor}`}>
            {meta.icon}
          </div>
          <div>
            <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${meta.badgeStyle}`}>
              {meta.badgeText}
            </span>
          </div>
        </div>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
          {meta.title}
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mb-6">
          {meta.description}
        </p>
        <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            共 {totalChapters} 章
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            最后更新：{latestUpdate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            作者：Maxwell Yu
          </span>
        </div>

        {mainChapters.length > 0 && (
          <div class="mt-8 flex gap-3">
            <a
              href={`/books/${bookSlug}/${(prefaceChapters[0] || mainChapters[0]).slug}`}
              class={`inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r ${meta.gradient} text-white font-semibold shadow-lg ${meta.shadowColor} hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200`}
            >
              开始阅读
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        )}
      </div>
    </div>

    <!-- Target Audience -->
    {meta.targetAudience && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
        {meta.targetAudience.map((item) => (
          <div class="card p-5">
            <div class={`w-10 h-10 rounded-xl ${item.colorClasses} flex items-center justify-center mb-3`}>
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h3 class="font-bold text-slate-900 dark:text-white mb-1">{item.title}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-400">{item.desc}</p>
          </div>
        ))}
      </div>
    )}

    <!-- Preface/Index sections if any -->
    {prefaceChapters.length > 0 && (
      <div class="mb-8">
        <div class="grid gap-3">
          {prefaceChapters.map((ch) => (
            <a href={`/books/${bookSlug}/${ch.slug}`} class="group block card card-hover overflow-hidden">
              <div class="flex">
                <div class={`w-1 shrink-0 bg-gradient-to-b from-slate-400 to-slate-500`} />
                <div class="flex-1 p-4 sm:p-5">
                  <div class="flex items-start gap-4">
                    <div class={`shrink-0 w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-sm font-bold text-slate-400 dark:text-slate-500 ${meta.groupHoverText} transition-colors`}>
                      {ch.data.chapter === 0 ? '目' : '序'}
                    </div>
                    <div class="flex-1 min-w-0">
                      <h4 class={`text-base font-semibold text-slate-900 dark:text-white ${meta.groupHoverText} transition-colors mb-1`}>
                        {ch.data.title}
                      </h4>
                      {ch.data.description && (
                        <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2">{ch.data.description}</p>
                      )}
                    </div>
                    <svg class={`w-5 h-5 text-slate-300 dark:text-slate-600 ${meta.groupHoverArrow} group-hover:translate-x-1 transition-all shrink-0 mt-1`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Table of Contents -->
    <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-6">目录</h2>

    {mainChapters.length > 0 ? (
      <div class="space-y-8">
        {[...partMap.entries()].length > 1 ? (
          /* Has parts - render grouped */
          [...partMap.entries()].map(([partName, partChapters]) => {
            const colors = (meta.partColors as any)[partName] || defaultPartColors;
            return (
              <div>
                {partName !== '正文' && (
                  <div class="flex items-center gap-3 mb-4">
                    <div class={`w-1 h-8 rounded-full bg-gradient-to-b ${colors.gradient}`} />
                    <h3 class="text-lg font-bold text-slate-900 dark:text-white">{partName}</h3>
                  </div>
                )}
                <div class="grid gap-3 pl-0 md:pl-4">
                  {partChapters.map((ch) => {
                    const chDisplayDate = ch.data.updatedDate || ch.data.date;
                    const formattedDate = chDisplayDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
                    return (
                      <a href={`/books/${bookSlug}/${ch.slug}`} class="group block card card-hover overflow-hidden">
                        <div class="flex">
                          <div class={`w-1 shrink-0 bg-gradient-to-b ${colors.gradient}`} />
                          <div class="flex-1 p-4 sm:p-5">
                            <div class="flex items-start gap-4">
                              <div class={`shrink-0 w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-sm font-bold text-slate-500 dark:text-slate-400 ${meta.groupHoverText} transition-colors`}>
                                {ch.data.chapter}
                              </div>
                              <div class="flex-1 min-w-0">
                                <h4 class={`text-base font-semibold text-slate-900 dark:text-white ${meta.groupHoverText} transition-colors mb-1`}>
                                  {ch.data.title}
                                </h4>
                                {ch.data.description && (
                                  <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2 mb-2">{ch.data.description}</p>
                                )}
                                <div class="flex flex-wrap items-center gap-2">
                                  <time class="text-xs text-slate-500 dark:text-slate-400">{formattedDate}</time>
                                  {ch.data.tags.slice(0, 3).map((tag) => (
                                    <span class="px-2 py-0.5 text-xs rounded-md bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 font-medium">{tag}</span>
                                  ))}
                                </div>
                              </div>
                              <svg class={`w-5 h-5 text-slate-300 dark:text-slate-600 ${meta.groupHoverArrow} group-hover:translate-x-1 transition-all shrink-0 mt-1`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                              </svg>
                            </div>
                          </div>
                        </div>
                      </a>
                    );
                  })}
                </div>
              </div>
            );
          })
        ) : (
          /* No parts - flat list */
          <div class="grid gap-3">
            {mainChapters.map((ch) => {
              const chDisplayDate = ch.data.updatedDate || ch.data.date;
              const formattedDate = chDisplayDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' });
              return (
                <a href={`/books/${bookSlug}/${ch.slug}`} class="group block card card-hover overflow-hidden">
                  <div class="flex">
                    <div class={`w-1 shrink-0 bg-gradient-to-b ${meta.gradient}`} />
                    <div class="flex-1 p-4 sm:p-5">
                      <div class="flex items-start gap-4">
                        <div class={`shrink-0 w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-sm font-bold text-slate-500 dark:text-slate-400 ${meta.groupHoverText} transition-colors`}>
                          {ch.data.chapter}
                        </div>
                        <div class="flex-1 min-w-0">
                          <h4 class={`text-base font-semibold text-slate-900 dark:text-white ${meta.groupHoverText} transition-colors mb-1`}>
                            {ch.data.title}
                          </h4>
                          {ch.data.description && (
                            <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2 mb-2">{ch.data.description}</p>
                          )}
                          <div class="flex flex-wrap items-center gap-2">
                            <time class="text-xs text-slate-500 dark:text-slate-400">{formattedDate}</time>
                            {ch.data.tags.slice(0, 3).map((tag) => (
                              <span class="px-2 py-0.5 text-xs rounded-md bg-slate-100 dark:bg-slate-800 text-slate-500 dark:text-slate-400 font-medium">{tag}</span>
                            ))}
                          </div>
                        </div>
                        <svg class={`w-5 h-5 text-slate-300 dark:text-slate-600 ${meta.groupHoverArrow} group-hover:translate-x-1 transition-all shrink-0 mt-1`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                        </svg>
                      </div>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <p class="text-slate-500 dark:text-slate-400">内容撰写中，敬请期待...</p>
      </div>
    )}
  </div>
</BaseLayout>
