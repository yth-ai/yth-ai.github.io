---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allChapters = (await getCollection('book'))
  .filter((ch) => !ch.data.draft)
  .sort((a, b) => a.data.chapter - b.data.chapter);

// Group by bookSlug
const bookMap = new Map<string, typeof allChapters>();
allChapters.forEach((ch) => {
  const slug = ch.data.bookSlug;
  if (!bookMap.has(slug)) bookMap.set(slug, []);
  bookMap.get(slug)!.push(ch);
});

// Book metadata
const booksMeta: Record<string, {
  title: string;
  subtitle: string;
  description: string;
  icon: string;
  gradient: string;
  shadowColor: string;
  chapters: number;
  status: string;
}> = {
  'llm-complete': {
    title: '大模型全书',
    subtitle: '从架构到训练到部署',
    description: '一本书成为大模型领域专家。从 Transformer 架构到数据工程，从预训练配方到对齐技术，从推理优化到 Agent 系统——基于一线实战经验，持续追踪前沿进展。',
    icon: '全',
    gradient: 'from-amber-500 to-orange-500',
    shadowColor: 'shadow-amber-500/25',
    chapters: bookMap.get('llm-complete')?.length || 0,
    status: '持续更新中',
  },
  'key-moments': {
    title: '大模型的关键时刻',
    subtitle: '九年、八个转折点，与一场未完的革命',
    description: '不是教科书，而是一部"认知简史"。过滤信息噪音，只留真正改变行业走向的关键节点——从 Transformer 到 ChatGPT，从 Scaling Laws 到推理革命。',
    icon: '键',
    gradient: 'from-indigo-500 to-purple-500',
    shadowColor: 'shadow-indigo-500/25',
    chapters: (bookMap.get('key-moments')?.filter(ch => ch.data.chapter > 0)?.length) || 0,
    status: '已完稿',
  },
  'data-engineering': {
    title: '大模型数据工程',
    subtitle: '从预训练到对齐的全链路实践',
    description: '第一本系统讲解大语言模型数据工程的专业书籍。从预训练数据到对齐数据，从认知演进到工程落地——一个过滤阈值的选择、一条坏样本的遗漏，可能让千万美元的训练功亏一篑。',
    icon: '数',
    gradient: 'from-emerald-500 to-teal-500',
    shadowColor: 'shadow-emerald-500/25',
    chapters: (bookMap.get('data-engineering')?.filter(ch => ch.data.chapter > 0 && ch.data.chapter < 100)?.length) || 0,
    status: '持续更新中',
  },
};

const bookOrder = ['llm-complete', 'data-engineering', 'key-moments'];
---

<BaseLayout title="书架" description="Maxwell 的书架——大模型领域深度书籍">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Hero -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-100 dark:bg-slate-800 text-sm font-medium text-slate-600 dark:text-slate-400 mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        Maxwell 的书架
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
        深度书籍
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl mx-auto">
        不写短平快，只写值得反复翻阅的内容。每一本都是对大模型领域某个维度的系统梳理。
      </p>
    </div>

    <!-- Book Cards -->
    <div class="grid gap-8">
      {bookOrder.map((bookSlug) => {
        const meta = booksMeta[bookSlug];
        const chapters = bookMap.get(bookSlug) || [];
        const firstChapter = chapters.find(ch => ch.data.chapter > 0) || chapters[0];
        const latestUpdate = chapters.length > 0
          ? new Date(Math.max(...chapters.map(ch => (ch.data.updatedDate || ch.data.date).valueOf())))
          : new Date();

        return (
          <div class="group relative overflow-hidden rounded-2xl border border-slate-200/70 dark:border-slate-700/50 bg-white dark:bg-slate-900 hover:shadow-xl hover:shadow-slate-200/50 dark:hover:shadow-black/20 transition-all duration-300">
            <div class="p-8 sm:p-10">
              <div class="flex flex-col sm:flex-row gap-6 sm:gap-8">
                {/* Book Icon */}
                <div class="shrink-0">
                  <div class={`w-20 h-20 rounded-2xl bg-gradient-to-br ${meta.gradient} flex items-center justify-center text-white text-3xl font-bold ${meta.shadowColor} shadow-lg group-hover:scale-105 transition-transform duration-300`}>
                    {meta.icon}
                  </div>
                </div>

                {/* Book Info */}
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-2">
                    <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 dark:text-white">
                      {meta.title}
                    </h2>
                    <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold ${
                      meta.status === '已完稿'
                        ? 'bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300'
                        : 'bg-amber-100 dark:bg-amber-900/50 text-amber-700 dark:text-amber-300'
                    }`}>
                      {meta.status}
                    </span>
                  </div>
                  <p class="text-base font-medium text-slate-500 dark:text-slate-400 mb-3 italic">
                    {meta.subtitle}
                  </p>
                  <p class="text-sm text-slate-600 dark:text-slate-400 mb-6 leading-relaxed max-w-2xl">
                    {meta.description}
                  </p>

                  {/* Stats */}
                  <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 dark:text-slate-400 mb-6">
                    <span class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                      {meta.chapters} 章
                    </span>
                    <span class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      最近更新：{latestUpdate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </span>
                    <span class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                      Maxwell Yu
                    </span>
                  </div>

                  {/* Actions */}
                  <div class="flex items-center gap-4">
                    <a
                      href={`/books/${bookSlug}`}
                      class={`inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r ${meta.gradient} text-white font-semibold ${meta.shadowColor} shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 text-sm`}
                    >
                      查看目录
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                    {firstChapter && (
                      <a
                        href={`/books/${bookSlug}/${firstChapter.slug}`}
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-300 font-medium hover:bg-slate-50 dark:hover:bg-slate-800 transition-all text-sm"
                      >
                        开始阅读
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    {/* Future Books Teaser */}
    <div class="mt-12 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-50 dark:bg-slate-800/50 border border-dashed border-slate-300 dark:border-slate-600 text-sm text-slate-500 dark:text-slate-400">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        更多书籍筹备中……
      </div>
    </div>
  </div>
</BaseLayout>
