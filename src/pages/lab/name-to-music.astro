---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NameToMusic from '../../components/lab/NameToMusic';
---

<BaseLayout title="用你的名字写首歌" description="每个汉字拆解为笔画，每种笔画映射一个音符——你的名字就是一段旋律">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">用你的名字写首歌</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">用你的名字写首歌</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">每个汉字拆解为笔画序列，每一笔映射一个音符——你的名字就是一段独一无二的旋律</p>
    </div>
    <NameToMusic client:load />
  </div>
</BaseLayout>
