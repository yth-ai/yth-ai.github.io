---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LifeInPixels from '../../components/lab/LifeInPixels';
---

<BaseLayout title="一生的像素" description="如果人生是 4160 个像素点，你已经用掉了多少？">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-4">
        <a href="/playground" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">探索</a>
        <span>/</span>
        <span class="text-slate-900 dark:text-white">一生的像素</span>
      </nav>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">一生的像素</h1>
      <p class="text-slate-600 dark:text-slate-400 mt-1">假设活到 80 岁，你的人生有 4160 个周——每个像素都是一周，已经灰去的再也回不来</p>
    </div>
    <LifeInPixels client:load />
  </div>
</BaseLayout>
