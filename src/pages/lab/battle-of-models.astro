---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="百模大战 · 一镜到底" description="100 个大模型的全景点阵图谱——星座图、时间线、排行榜、传承树四种视图">
  <a href="/playground" class="fixed top-20 left-4 z-50 inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-slate-600 dark:text-slate-300 bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm rounded-full shadow-md hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    返回探索
  </a>
  <div id="app"></div>
</BaseLayout>

<script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import BattleOfModels from '../../components/lab/BattleOfModels';

  const root = createRoot(document.getElementById('app')!);
  root.render(createElement(BattleOfModels));
</script>
