---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allChangelogs = (await getCollection('changelog'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf() || b.slug.localeCompare(a.slug));

// Group by month
const monthGroups = new Map<string, typeof allChangelogs>();
allChangelogs.forEach((entry) => {
  const key = entry.data.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' });
  if (!monthGroups.has(key)) monthGroups.set(key, []);
  monthGroups.get(key)!.push(entry);
});

// Type config
const typeConfig: Record<string, { label: string; color: string; dotColor: string; icon: string }> = {
  content: {
    label: '新内容',
    color: 'bg-emerald-50 dark:bg-emerald-950/30 text-emerald-700 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800',
    dotColor: 'bg-emerald-500',
    icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  },
  feature: {
    label: '新功能',
    color: 'bg-blue-50 dark:bg-blue-950/30 text-blue-700 dark:text-blue-300 border-blue-200 dark:border-blue-800',
    dotColor: 'bg-blue-500',
    icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z',
  },
  improve: {
    label: '优化',
    color: 'bg-amber-50 dark:bg-amber-950/30 text-amber-700 dark:text-amber-300 border-amber-200 dark:border-amber-800',
    dotColor: 'bg-amber-500',
    icon: 'M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z',
  },
  fix: {
    label: '修复',
    color: 'bg-rose-50 dark:bg-rose-950/30 text-rose-700 dark:text-rose-300 border-rose-200 dark:border-rose-800',
    dotColor: 'bg-rose-500',
    icon: 'M11.42 15.17l-4.655-5.653a.78.78 0 010-1.034l4.655-5.653a.78.78 0 011.16 0l4.655 5.653a.78.78 0 010 1.034l-4.655 5.653a.78.78 0 01-1.16 0z',
  },
};

// Stats
const totalEntries = allChangelogs.length;
const contentCount = allChangelogs.reduce((acc, e) => acc + e.data.changes.filter(c => c.type === 'content').length, 0);
const featureCount = allChangelogs.reduce((acc, e) => acc + e.data.changes.filter(c => c.type === 'feature').length, 0);
---

<BaseLayout title="更新日志" description="Maxwell 站点更新日志——内容更新、功能迭代、优化改进一览">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page Header -->
    <div class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-accent-500 flex items-center justify-center shadow-lg shadow-primary-500/25">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h1 class="text-3xl font-bold text-slate-900 dark:text-white">更新日志</h1>
          <p class="text-slate-500 dark:text-slate-400 text-sm mt-0.5">记录每一次进化</p>
        </div>
      </div>

      <!-- Stats Bar -->
      <div class="flex flex-wrap gap-4 mt-6">
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-slate-100 dark:bg-slate-800 text-sm">
          <span class="text-slate-500 dark:text-slate-400">共</span>
          <span class="font-semibold text-slate-900 dark:text-white">{totalEntries}</span>
          <span class="text-slate-500 dark:text-slate-400">次更新</span>
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-emerald-50 dark:bg-emerald-950/30 text-sm">
          <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
          <span class="font-medium text-emerald-700 dark:text-emerald-300">{contentCount} 项内容</span>
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-blue-50 dark:bg-blue-950/30 text-sm">
          <div class="w-2 h-2 rounded-full bg-blue-500"></div>
          <span class="font-medium text-blue-700 dark:text-blue-300">{featureCount} 项功能</span>
        </div>
      </div>

      <!-- Legend -->
      <div class="flex flex-wrap gap-3 mt-4">
        {Object.entries(typeConfig).map(([key, cfg]) => (
          <span class:list={['inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium border', cfg.color]}>
            <div class:list={['w-1.5 h-1.5 rounded-full', cfg.dotColor]} />
            {cfg.label}
          </span>
        ))}
      </div>
    </div>

    {allChangelogs.length > 0 ? (
      <!-- Timeline -->
      <div class="relative">
        <!-- Timeline Line -->
        <div class="absolute left-[19px] top-0 bottom-0 w-px bg-slate-200 dark:bg-slate-700" />

        {[...monthGroups.entries()].map(([month, entries]) => (
          <div class="mb-10">
            <!-- Month Header -->
            <div class="relative flex items-center gap-4 mb-6">
              <div class="w-10 h-10 rounded-full bg-primary-100 dark:bg-primary-950/50 border-2 border-primary-300 dark:border-primary-700 flex items-center justify-center z-10">
                <svg class="w-4 h-4 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
              </div>
              <h2 class="text-lg font-bold text-slate-900 dark:text-white">{month}</h2>
            </div>

            <!-- Entries -->
            <div class="space-y-4">
              {entries.map((entry) => {
                const formattedDate = entry.data.date.toLocaleDateString('zh-CN', {
                  month: 'numeric',
                  day: 'numeric',
                  weekday: 'short',
                });
                return (
                  <div class="relative pl-14">
                    <!-- Timeline Dot -->
                    <div class="absolute left-[15px] top-5 w-[11px] h-[11px] rounded-full bg-white dark:bg-slate-900 border-2 border-slate-300 dark:border-slate-600 z-10" />

                    <!-- Entry Card -->
                    <div class="card p-5 hover:shadow-md transition-shadow">
                      <!-- Header -->
                      <div class="flex items-center justify-between gap-3 mb-3">
                        <div class="flex items-center gap-2">
                          {entry.data.version && (
                            <span class="px-2 py-0.5 rounded-md bg-primary-50 dark:bg-primary-950/50 text-primary-600 dark:text-primary-400 text-xs font-mono font-semibold">
                              {entry.data.version}
                            </span>
                          )}
                          <h3 class="font-semibold text-slate-900 dark:text-white text-base">
                            {entry.data.title}
                          </h3>
                        </div>
                        <time datetime={entry.data.date.toISOString()} class="text-xs text-slate-400 dark:text-slate-500 whitespace-nowrap">
                          {formattedDate}
                        </time>
                      </div>

                      <!-- Changes List -->
                      {entry.data.changes.length > 0 && (
                        <ul class="space-y-2">
                          {entry.data.changes.map((change) => {
                            const cfg = typeConfig[change.type];
                            return (
                              <li class="flex items-start gap-2.5">
                                <span class:list={['inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold border shrink-0 mt-0.5', cfg.color]}>
                                  <div class:list={['w-1.5 h-1.5 rounded-full', cfg.dotColor]} />
                                  {cfg.label}
                                </span>
                                {change.link ? (
                                  <a href={change.link} class="text-sm text-slate-700 dark:text-slate-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors underline decoration-slate-300 dark:decoration-slate-600 underline-offset-2 hover:decoration-primary-400 dark:hover:decoration-primary-500">
                                    {change.summary}
                                    <svg class="inline-block w-3 h-3 ml-0.5 -mt-0.5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
                                  </a>
                                ) : (
                                  <span class="text-sm text-slate-700 dark:text-slate-300">{change.summary}</span>
                                )}
                              </li>
                            );
                          })}
                        </ul>
                      )}

                      <!-- Markdown body (if any) -->
                      {entry.body && entry.body.trim() && (
                        <div class="mt-4 pt-3 border-t border-slate-100 dark:border-slate-700/50">
                          <details class="group">
                            <summary class="flex items-center gap-1.5 text-xs text-slate-400 dark:text-slate-500 cursor-pointer hover:text-slate-600 dark:hover:text-slate-400 transition-colors">
                              <svg class="w-3.5 h-3.5 transform group-open:rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                              </svg>
                              详细说明
                            </summary>
                            <div class="mt-2 text-sm text-slate-600 dark:text-slate-400 prose-custom prose-sm" set:html={entry.body} />
                          </details>
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ))}

        <!-- Timeline End -->
        <div class="relative flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-slate-100 dark:bg-slate-800 border-2 border-slate-300 dark:border-slate-600 flex items-center justify-center z-10">
            <svg class="w-4 h-4 text-slate-400 dark:text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-2.25-1.313M21 7.5v2.25m0-2.25l-2.25 1.313M3 7.5l2.25-1.313M3 7.5l2.25 1.313M3 7.5v2.25m9 3l2.25-1.313M12 12.75l-2.25-1.313M12 12.75V15m0 6.75l2.25-1.313M12 21.75V19.5m0 2.25l-2.25-1.313m0-16.875L12 2.25l2.25 1.313M21 14.25v2.25l-2.25 1.313m-13.5 0L3 16.5v-2.25" />
            </svg>
          </div>
          <span class="text-sm text-slate-400 dark:text-slate-500 italic">Maxwell 的起点</span>
        </div>
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-slate-400">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="text-slate-500 dark:text-slate-400">暂无更新日志</p>
        <p class="text-sm text-slate-400 dark:text-slate-500 mt-1">在 src/content/changelog/ 目录下添加 Markdown 文件即可</p>
      </div>
    )}
  </div>
</BaseLayout>
