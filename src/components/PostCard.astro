---
interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  category?: string;
  href: string;
  type?: 'doc' | 'blog';
}

const { title, description, date, tags = [], category, href, type = 'blog' } = Astro.props;

const categoryColors = {
  '技术文档': 'bg-emerald-500',
  '教程指南': 'bg-amber-500',
  '深度解析': 'bg-purple-500',
  '公告': 'bg-slate-500',
};

const borderColor = category ? (categoryColors[category] || 'bg-primary-500') : 'bg-primary-500';

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={href} class="group block card card-hover overflow-hidden">
  <div class="flex">
    {type === 'doc' && (
      <div class={`w-1 shrink-0 ${borderColor}`} />
    )}
    <div class="flex-1 p-5 sm:p-6">
      <div class="flex items-center gap-3 mb-2 text-xs text-slate-500 dark:text-slate-400">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {category && (
          <span class="px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 font-medium">
            {category}
          </span>
        )}
      </div>
      <h3 class="text-lg font-semibold text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors mb-2">
        {title}
      </h3>
      {description && (
        <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2 mb-3">
          {description}
        </p>
      )}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="px-2 py-0.5 text-xs rounded-md bg-primary-50 dark:bg-primary-950/50 text-primary-600 dark:text-primary-400 font-medium">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</a>
