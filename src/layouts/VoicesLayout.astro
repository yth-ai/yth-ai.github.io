---
import BaseLayout from './BaseLayout.astro';
import BookmarkButton from '../components/tools/BookmarkButton';
import ContentHub from '../components/tools/ContentHub';

interface MediaItem {
  title: string;
  sourceUrl: string;
  platform: 'youtube' | 'podcast' | 'x' | 'bilibili' | 'blog' | 'news' | 'other';
  sourceType: 'video' | 'podcast' | 'thread' | 'article' | 'live';
  author?: string;
  duration?: string;
  summary: string;
}

interface Props {
  title: string;
  description?: string;
  date: Date;
  volume: number;
  tags?: string[];
  items?: MediaItem[];
  headings?: { depth: number; slug: string; text: string }[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}

const { title, description, date, volume, tags = [], items = [], headings = [], prevPost, nextPost } = Astro.props;

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const platformConfig: Record<string, { label: string; icon: string; color: string; bgColor: string }> = {
  youtube: {
    label: 'YouTube',
    icon: 'M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
    color: 'text-red-600 dark:text-red-400',
    bgColor: 'bg-red-50 dark:bg-red-950/30',
  },
  podcast: {
    label: '播客',
    icon: 'M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3zM19 10v2a7 7 0 01-14 0v-2H3v2a9 9 0 004 7.48V22h2v-2.26a9.003 9.003 0 002 .26 9.003 9.003 0 002-.26V22h2v-2.52A9 9 0 0021 12v-2h-2z',
    color: 'text-purple-600 dark:text-purple-400',
    bgColor: 'bg-purple-50 dark:bg-purple-950/30',
  },
  x: {
    label: 'X',
    icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
    color: 'text-slate-800 dark:text-slate-200',
    bgColor: 'bg-slate-100 dark:bg-slate-800',
  },
  bilibili: {
    label: 'Bilibili',
    icon: 'M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 01-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 01.16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z',
    color: 'text-cyan-600 dark:text-cyan-400',
    bgColor: 'bg-cyan-50 dark:bg-cyan-950/30',
  },
  blog: {
    label: '博客',
    icon: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z',
    color: 'text-emerald-600 dark:text-emerald-400',
    bgColor: 'bg-emerald-50 dark:bg-emerald-950/30',
  },
  news: {
    label: '新闻',
    icon: 'M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z',
    color: 'text-amber-600 dark:text-amber-400',
    bgColor: 'bg-amber-50 dark:bg-amber-950/30',
  },
  other: {
    label: '其他',
    icon: 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.07a4.5 4.5 0 00-1.242-7.244l-4.5-4.5a4.5 4.5 0 00-6.364 6.364L4.243 8.88',
    color: 'text-slate-600 dark:text-slate-400',
    bgColor: 'bg-slate-50 dark:bg-slate-800',
  },
};

const sourceTypeLabels: Record<string, string> = {
  video: '视频',
  podcast: '播客',
  thread: '讨论串',
  article: '文章',
  live: '直播',
};

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout title={`${title} | 前沿声浪`} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class:list={[tocHeadings.length > 0 ? 'lg:grid lg:grid-cols-[1fr_220px] lg:gap-12' : '']}>
      <!-- Main Content -->
      <article class="min-w-0">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-6">
          <a href="/voices" class="hover:text-rose-600 dark:hover:text-rose-400 transition-colors">前沿声浪</a>
          <span>/</span>
          <span class="text-slate-900 dark:text-white">Vol.{volume}</span>
        </nav>

        <!-- Title Area -->
        <header class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-semibold border bg-rose-50 dark:bg-rose-950/30 text-rose-700 dark:text-rose-300 border-rose-200 dark:border-rose-800">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
              </svg>
              前沿声浪 · Vol.{volume}
            </span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3 text-balance">
            {title}
          </h1>
          {description && (
            <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">{description}</p>
          )}
          <div class="flex flex-wrap items-center gap-3 text-sm">
            <time datetime={date.toISOString()} class="text-slate-500 dark:text-slate-400">
              {formattedDate}
            </time>
            {tags.map((tag) => (
              <span class="px-2.5 py-0.5 rounded-full bg-rose-50 dark:bg-rose-950/50 text-rose-600 dark:text-rose-400 font-medium text-xs">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-4">
            <BookmarkButton client:load collection="voices" />
          </div>
        </header>

        <!-- Media Items Quick Access -->
        {items.length > 0 && (
          <div class="mb-10">
            <h2 class="text-sm font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-4">
              本期内容 · {items.length} 条
            </h2>
            <div class="space-y-3">
              {items.map((item, i) => {
                const cfg = platformConfig[item.platform] || platformConfig.other;
                const typeLabel = sourceTypeLabels[item.sourceType] || item.sourceType;
                return (
                  <a
                    href={item.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group block rounded-xl border border-slate-200 dark:border-slate-700 hover:border-rose-300 dark:hover:border-rose-700 transition-all duration-200 overflow-hidden hover:shadow-md"
                  >
                    <div class="flex items-stretch">
                      {/* Play / Source indicator */}
                      <div class={`w-14 sm:w-16 shrink-0 flex flex-col items-center justify-center gap-1 ${cfg.bgColor}`}>
                        {item.sourceType === 'video' ? (
                          <svg class={`w-6 h-6 ${cfg.color}`} fill="currentColor" viewBox="0 0 24 24">
                            <path d="M8 5v14l11-7z" />
                          </svg>
                        ) : item.sourceType === 'podcast' ? (
                          <svg class={`w-6 h-6 ${cfg.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d={platformConfig.podcast.icon} />
                          </svg>
                        ) : (
                          <svg class={`w-5 h-5 ${cfg.color}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                          </svg>
                        )}
                        {item.duration && (
                          <span class={`text-[10px] font-mono font-medium ${cfg.color}`}>{item.duration}</span>
                        )}
                      </div>
                      {/* Content */}
                      <div class="flex-1 p-3 sm:p-4 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          <span class={`inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-semibold ${cfg.bgColor} ${cfg.color}`}>
                            {cfg.label}
                          </span>
                          <span class="text-[10px] text-slate-400 dark:text-slate-500 font-medium">
                            {typeLabel}
                          </span>
                          {item.author && (
                            <span class="text-[10px] text-slate-400 dark:text-slate-500 truncate">
                              · {item.author}
                            </span>
                          )}
                        </div>
                        <h3 class="text-sm font-semibold text-slate-900 dark:text-white group-hover:text-rose-600 dark:group-hover:text-rose-400 transition-colors line-clamp-1 mb-0.5">
                          {item.title}
                        </h3>
                        <p class="text-xs text-slate-500 dark:text-slate-400 line-clamp-1">
                          {item.summary}
                        </p>
                      </div>
                      {/* Arrow */}
                      <div class="hidden sm:flex items-center px-3 text-slate-300 dark:text-slate-600 group-hover:text-rose-400 transition-colors">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                        </svg>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Full Content -->
        <div class="prose-custom">
          <slot />
        </div>

        <!-- Post Navigation -->
        {(prevPost || nextPost) && (
          <nav class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-700">
            <div class="grid grid-cols-2 gap-4">
              {prevPost ? (
                <a href={`/voices/${prevPost.slug}`} class="group card p-4 hover:border-rose-300 dark:hover:border-rose-600">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">上一期</span>
                  <p class="text-sm font-medium text-slate-900 dark:text-white group-hover:text-rose-600 dark:group-hover:text-rose-400 mt-1 line-clamp-2">{prevPost.title}</p>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={`/voices/${nextPost.slug}`} class="group card p-4 text-right hover:border-rose-300 dark:hover:border-rose-600">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">下一期</span>
                  <p class="text-sm font-medium text-slate-900 dark:text-white group-hover:text-rose-600 dark:group-hover:text-rose-400 mt-1 line-clamp-2">{nextPost.title}</p>
                </a>
              ) : <div />}
            </div>
          </nav>
        )}
      </article>

      <!-- Table of Contents (Desktop) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-4 uppercase tracking-wider">
              本期目录
            </h4>
            <nav class="space-y-1">
              {tocHeadings.map((heading) => (
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'block text-sm transition-colors duration-200 hover:text-rose-600 dark:hover:text-rose-400',
                    heading.depth === 2
                      ? 'text-slate-600 dark:text-slate-400 font-medium'
                      : 'text-slate-500 dark:text-slate-500 pl-4',
                  ]}
                >
                  {heading.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </div>
  <ContentHub client:load />
</BaseLayout>
