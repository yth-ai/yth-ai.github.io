---
import BaseLayout from './BaseLayout.astro';
import ContentHub from '../components/tools/ContentHub';
import BookmarkButton from '../components/tools/BookmarkButton';

interface Props {
  title: string;
  description?: string;
  date: Date;
  series: string;
  volume: number;
  tags?: string[];
  headings?: { depth: number; slug: string; text: string }[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}

const { title, description, date, series, volume, tags = [], headings = [], prevPost, nextPost } = Astro.props;

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const seriesColors: Record<string, { bg: string; text: string; border: string }> = {
  'AI 前沿速递': { bg: 'bg-blue-50 dark:bg-blue-950/30', text: 'text-blue-700 dark:text-blue-300', border: 'border-blue-200 dark:border-blue-800' },
  '数据工程观察': { bg: 'bg-emerald-50 dark:bg-emerald-950/30', text: 'text-emerald-700 dark:text-emerald-300', border: 'border-emerald-200 dark:border-emerald-800' },
  '数据论文速递': { bg: 'bg-violet-50 dark:bg-violet-950/30', text: 'text-violet-700 dark:text-violet-300', border: 'border-violet-200 dark:border-violet-800' },
  '大模型前沿动态': { bg: 'bg-orange-50 dark:bg-orange-950/30', text: 'text-orange-700 dark:text-orange-300', border: 'border-orange-200 dark:border-orange-800' },
};

const colors = seriesColors[series] || { bg: 'bg-primary-50 dark:bg-primary-950/30', text: 'text-primary-700 dark:text-primary-300', border: 'border-primary-200 dark:border-primary-800' };

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout title={`${title} | ${series}`} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class:list={[tocHeadings.length > 0 ? 'lg:grid lg:grid-cols-[1fr_220px] lg:gap-12' : '']}>
      <!-- Main Content -->
      <article class="min-w-0">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-6">
          <a href="/column" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">专栏</a>
          <span>/</span>
          <span class={colors.text}>{series}</span>
          <span>/</span>
          <span class="text-slate-900 dark:text-white">Vol.{volume}</span>
        </nav>

        <!-- Title Area -->
        <header class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
          <!-- Series badge -->
          <div class="flex items-center gap-3 mb-4">
            <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-semibold border ${colors.bg} ${colors.text} ${colors.border}`}>
              {series} · Vol.{volume}
            </span>
          </div>

          <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3 text-balance">
            {title}
          </h1>
          {description && (
            <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">{description}</p>
          )}
          <div class="flex flex-wrap items-center gap-3 text-sm">
            <time datetime={date.toISOString()} class="text-slate-500 dark:text-slate-400">
              {formattedDate}
            </time>
            {tags.map((tag) => (
              <span class="px-2.5 py-0.5 rounded-full bg-primary-50 dark:bg-primary-950/50 text-primary-600 dark:text-primary-400 font-medium text-xs">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-4">
            <BookmarkButton client:load collection="column" />
          </div>
        </header>

        <!-- Content -->
        <div class="prose-custom">
          <slot />
        </div>

        <!-- Post Navigation -->
        {(prevPost || nextPost) && (
          <nav class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-700">
            <div class="grid grid-cols-2 gap-4">
              {prevPost ? (
                <a href={`/column/${prevPost.slug}`} class="group card p-4 hover:border-primary-300 dark:hover:border-primary-600">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">上一期</span>
                  <p class="text-sm font-medium text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 mt-1 line-clamp-2">{prevPost.title}</p>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={`/column/${nextPost.slug}`} class="group card p-4 text-right hover:border-primary-300 dark:hover:border-primary-600">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">下一期</span>
                  <p class="text-sm font-medium text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 mt-1 line-clamp-2">{nextPost.title}</p>
                </a>
              ) : <div />}
            </div>
          </nav>
        )}
      </article>

      <!-- Table of Contents (Desktop) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-4 uppercase tracking-wider">
              本期目录
            </h4>
            <nav class="space-y-1">
              {tocHeadings.map((heading) => (
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'block text-sm transition-colors duration-200 hover:text-primary-600 dark:hover:text-primary-400',
                    heading.depth === 2
                      ? 'text-slate-600 dark:text-slate-400 font-medium'
                      : 'text-slate-500 dark:text-slate-500 pl-4',
                  ]}
                >
                  {heading.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </div>
  <!-- 统一浮标：收藏 + 精读队列 + arXiv 链接扫描 -->
  <ContentHub client:load />
</BaseLayout>
