---
import BaseLayout from './BaseLayout.astro';
import BookmarkButton from '../components/tools/BookmarkButton';
import ContentHub from '../components/tools/ContentHub';

interface Props {
  title: string;
  description?: string;
  date: Date;
  category?: string;
  tags?: string[];
  headings?: { depth: number; slug: string; text: string }[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}

const { title, description, date, category, tags = [], headings = [], prevPost, nextPost } = Astro.props;

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const categoryColors = {
  '技术文档': 'bg-emerald-100 dark:bg-emerald-950/40 text-emerald-700 dark:text-emerald-300',
  '教程指南': 'bg-amber-100 dark:bg-amber-950/40 text-amber-700 dark:text-amber-300',
  '深度解析': 'bg-purple-100 dark:bg-purple-950/40 text-purple-700 dark:text-purple-300',
  '公告': 'bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300',
};

const categoryClass = category ? (categoryColors[category] || 'bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300') : '';
---

<BaseLayout title={title} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class:list={[tocHeadings.length > 0 ? 'lg:grid lg:grid-cols-[1fr_240px] lg:gap-12' : '']}>
      <!-- Main Content -->
      <article class="min-w-0 max-w-3xl mx-auto lg:mx-0 lg:max-w-none">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm text-slate-500 dark:text-slate-400 mb-6">
          <a href="/articles" class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">文章</a>
          {category && (
            <>
              <span>/</span>
              <span>{category}</span>
            </>
          )}
        </nav>

        <!-- Title Area -->
        <header class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
          <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-3 text-balance">
            {title}
          </h1>
          {description && (
            <p class="text-lg text-slate-600 dark:text-slate-400 mb-4">{description}</p>
          )}
          <div class="flex flex-wrap items-center gap-3 text-sm">
            <time datetime={date.toISOString()} class="text-slate-500 dark:text-slate-400">
              {formattedDate}
            </time>
            {category && (
              <span class:list={['px-2.5 py-0.5 rounded-full font-medium text-xs', categoryClass]}>
                {category}
              </span>
            )}
            {tags.map((tag) => (
              <span class="px-2.5 py-0.5 rounded-full bg-primary-50 dark:bg-primary-950/50 text-primary-600 dark:text-primary-400 font-medium text-xs">
                {tag}
              </span>
            ))}
          </div>
          <div class="mt-4">
            <BookmarkButton client:load collection="articles" />
          </div>
        </header>

        <!-- Content -->
        <div class="prose-custom">
          <slot />
        </div>

        <!-- Post Navigation -->
        {(prevPost || nextPost) && (
          <nav class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-700">
            <div class="grid grid-cols-2 gap-4">
              {prevPost ? (
                <a href={`/articles/${prevPost.slug}`} class="group card p-4 hover:border-primary-300 dark:hover:border-primary-600">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">上一篇</span>
                  <p class="text-sm font-medium text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 mt-1 line-clamp-2">{prevPost.title}</p>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={`/articles/${nextPost.slug}`} class="group card p-4 text-right hover:border-primary-300 dark:hover:border-primary-600">
                  <span class="text-xs text-slate-500 dark:text-slate-400 uppercase tracking-wider">下一篇</span>
                  <p class="text-sm font-medium text-slate-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 mt-1 line-clamp-2">{nextPost.title}</p>
                </a>
              ) : <div />}
            </div>
          </nav>
        )}
      </article>

      <!-- Table of Contents (Desktop) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <h4 class="text-sm font-semibold text-slate-900 dark:text-white mb-4 uppercase tracking-wider">
              目录
            </h4>
            <nav class="space-y-1">
              {tocHeadings.map((heading) => (
                <a
                  href={`#${heading.slug}`}
                  class:list={[
                    'block text-sm transition-colors duration-200 hover:text-primary-600 dark:hover:text-primary-400',
                    heading.depth === 2
                      ? 'text-slate-600 dark:text-slate-400 font-medium'
                      : 'text-slate-500 dark:text-slate-500 pl-4',
                  ]}
                >
                  {heading.text}
                </a>
              ))}
            </nav>
          </div>
        </aside>
      )}
    </div>
  </div>
  <ContentHub client:load />
</BaseLayout>
